# ============================================
# CLISONIX CLOUD - ENVIRONMENT TEMPLATE
# ============================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to version control!

# ---- Server / Deployment ----
HETZNER_IP=46.224.203.89
DEPLOY_PATH=/root/Clisonix-cloud
SERVER_USER=root

# ---- Service Ports ----
PORT_WEB=3000
PORT_API=8000
PORT_OCEAN=8030
PORT_ALBA=5555
PORT_ALBI=6680
PORT_JONA=7777
PORT_ASI=9094
PORT_CYCLE=8050
PORT_LIAM=8062
PORT_ALDA=8063
PORT_ALPHABET=8061
PORT_AGIEM=9300

# ---- Ollama (Local LLM) ----
OLLAMA_HOST=localhost
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
# STRICT RULES - DO NOT CHANGE THESE VALUES!
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PREDICT=4096
OLLAMA_NUM_CTX=8192

# ---- API Configuration ----
API_SECRET_KEY=your-secret-key-here
API_KEY_HEADER=X-API-Key
ALLOWED_API_KEYS=key1,key2,key3

# ---- JWT ----
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# ---- Database ----
POSTGRES_USER=clisonix
POSTGRES_PASSWORD=your-db-password-here
POSTGRES_DB=clisonixdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://clisonix:password@localhost:5432/clisonixdb

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://default:password@localhost:6379/0

# ---- Neo4j ----
NEO4J_URI=neo4j://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ---- Vector DB ----
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-key

# ---- InfluxDB (Time Series) ----
INFLUXDB_URL=http://localhost:8086
INFLUXDB_ORG=clisonix
INFLUXDB_BUCKET=metrics
INFLUXDB_TOKEN=your-influxdb-token

# ---- MinIO Storage ----
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false

# ---- Keycloak Auth ----
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=clisonix
KEYCLOAK_CLIENT_ID=clisonix-app
KEYCLOAK_CLIENT_SECRET=your-keycloak-secret

# ---- Payment Gateways ----
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_SECRET=your-paypal-secret
PAYPAL_BASE=https://api-m.sandbox.paypal.com

STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ---- Slack Integration ----
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
SLACK_CHANNEL=#clisonix-alerts
SLACK_ENABLED=false

# ---- Third-party APIs ----
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CHANNEL_ID=UCuCd7kgikh6CM2hAh5eAIMA
GITHUB_TOKEN=your-github-token

# ---- Monitoring ----
PROMETHEUS_PORT=9090
GRAFANA_ADMIN_PASSWORD=admin
LOKI_URL=http://localhost:3100

# ---- Application ----
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3004
# LinkedIn API Credentials
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=urn:li:organization:111866162
